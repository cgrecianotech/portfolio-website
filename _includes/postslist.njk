<ol reversed class="postlist" style="--postlist-index: {{ (postslistCounter or postslist.length) + 1 }}">
{%- for post in postslist | reverse %}
	<li class="postlist-item{% if post.url == url %} postlist-item-active{% endif %}">
		<a href="{{ post.url }}" class="postlist-link">
			{% if post.data.title %}
				{{ post.data.title }}
			{% else %}
				<code>{{ post.url }}</code>
			{% endif %}
		</a>
		{% set readingTimeResult = post.content | estimatedReadingTime %}
		<time class="postlist-date" datetime="{{ post.date | htmlDateString }}">
			{{ post.date | readableDate("LLLL yyyy") }}
			<strong>({{ readingTimeResult.readingTime }})</strong>
		</time>
		{% if post.data.description %}
		<p class="postlist-description"><i>{{ post.data.description }}</i></p>
		{% endif %}
		<hr class="postlist-separator" />
	</li>
{%- endfor %}
</ol>
